# BoardMate backend environment configuration
# Copy this file to .env at the repository root and fill in your values.

APP_ENV=development

# Backend security
# Required in production.
SECRET_KEY=replace-this-with-a-long-random-string
# Optional in development. Required in production to enable /admin routes.
ADMIN_TOKEN=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Backend runtime
# Comma-separated list for local or deployed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional. Defaults to ./Books
DATA_DIR=
# Optional. Defaults to backend/app/storage/app.db
DATABASE_URL=

# Groq LLM settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Embedding model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# RAG settings
CHUNK_SIZE=400
CHUNK_OVERLAP=60
TOP_K_RESULTS=5
